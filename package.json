{
  "name": "llm-context-optimizer",
  "version": "1.0.4",
  "description": "Intelligent context preprocessing for LLMs - reduces tokens, improves relevance, preserves critical information",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "llm-context-optimizer": "bin/llm-context-optimizer.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "llm",
    "context",
    "optimizer",
    "prompt",
    "token",
    "compression"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "chalk": "^5.3.0",
    "glob": "^10.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.46.1",
    "typescript": "^5.5.0",
    "tsup": "^8.1.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.39.1",
    "prettier": "^3.3.0"
  }
}
